<?xml version="1.0" encoding="UTF-8"?>
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application
        id="730e028ac94842c5b2c42b8e132ab88b"
        type="watchface"
        name="@Strings.AppName"
        entry="YellowGoldApp"
        launcherIcon="@Drawables.LauncherIcon"
        minApiLevel="6.0.0">

        <!-- Fenix 8 Pro (454x454 round). NOTE: Connect IQ SDK 9.2.0 only ships a
             "fenix8pro47mm" device id; there is no "fenix8pro51mm" target, so it
             was removed (it fails the build with "Invalid device id"). Re-add the
             51mm id here if a future SDK introduces it. -->
        <iq:products>
            <iq:product id="fenix8pro47mm"/>
        </iq:products>

        <iq:permissions>
            <!-- Body Battery / heart-rate history are read via Toybox.SensorHistory. -->
            <iq:uses-permission id="SensorHistory"/>
        </iq:permissions>

        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
